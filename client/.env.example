# Game server URL for local development.
# NOTE: boardgame.io's SocketIO transport wants a bare host:port or an
# http(s):// URL — NOT ws:// or wss:// (socket.io negotiates the WebSocket
# upgrade itself).
VITE_SERVER_URL=localhost:3000

# For production (on Netlify), use the deployed Render server URL.
# Must be https:// (not http://) or the browser will block it as mixed
# content once the Netlify site is served over https.
# VITE_SERVER_URL=https://3k-game-server.onrender.com
